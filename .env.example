# ═══════════════════════════════════════════════════════════
# WINNER STORE — Configuración Local
# ═══════════════════════════════════════════════════════════
# 
# Copia este archivo a .env (backend/.env)
# Este archivo NO está en .gitignore (es configuración default)

# ─── AMBIENTE ───────────────────────────────────────────────
NODE_ENV=development
# Mantener en development para servidor local

# ─── PUERTO ─────────────────────────────────────────────────
PORT=3000
# Puerto donde corre el servidor local

# ─── BASE DE DATOS ──────────────────────────────────────────
DB_TYPE=sqlite
# SQLite es el estándar para servidor local
# No requiere configuración externa

# Ruta de base de datos SQLite
DB_PATH=./backend/winner_store.db

# ─── AUTENTICACIÓN JWT ──────────────────────────────────────
JWT_SECRET=dev-jwt-secret-winner-2026
# Para desarrollo local está bien este valor

# ─── CREDENCIALES ADMIN ─────────────────────────────────────
ADMIN_USER=admin
ADMIN_PASSWORD=winner2026
# Credenciales para acceder a /admin-panel.html

ADMIN_SALT=winner_salt_2026

# ─── SEGURIDAD API ──────────────────────────────────────────
API_KEY=dev-api-key
# Para desarrollo local, está bien este valor

# ─── CORS (Control de origen) ───────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Localhos solo - no hay acceso externo

# ─── LOGGING ────────────────────────────────────────────────
LOG_LEVEL=info
# Niveles: debug | info | warn | error

# ─── LÍMITES Y TIMEOUTS ────────────────────────────────────
# Límite de tamaño de request
BODY_LIMIT=15mb

# Timeout de sesión (minutos)
SESSION_TIMEOUT=60

# EMAIL_PROVIDER=sendgrid|aws-ses|mailgun
# EMAIL_FROM=noreply@winner-store.com
# EMAIL_API_KEY=your_email_api_key

# SMS_PROVIDER=twilio|aws-sns
# SMS_API_KEY=your_sms_api_key
# SMS_PHONE=+573001234567

# ─── MONITOREO ─────────────────────────────────────────────
# SENTRY_DSN=your_sentry_dsn_for_error_tracking
# ANALYTICS_ID=your_google_analytics_id
