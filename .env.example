# ═══════════════════════════════════════════════════════════
# WINNER STORE — Production Configuration
# ═══════════════════════════════════════════════════════════
# 
# Copia este archivo a .env y configura según tu ambiente
# NO COMPARTIR este archivo en repositorio (incluido en .gitignore)

# ─── AMBIENTE ───────────────────────────────────────────────
NODE_ENV=development
# Opciones: development | staging | production

# ─── PUERTO ─────────────────────────────────────────────────
PORT=3000
# En producción, usar 8000 o similar (no <1024 sin permisos root)

# ─── BASE DE DATOS ──────────────────────────────────────────
DB_TYPE=sqlite
# Opciones: sqlite | postgres
# Por defecto: sqlite (sin dependencias externas)

# Para PostgreSQL, descomenta y configura:
# DATABASE_URL=postgresql://username:password@host:5432/winner_store
# O configurar por partes:
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=winner_store
# DB_USER=postgres
# DB_PASSWORD=your_secure_password

# Ruta de base de datos SQLite (ignorado si DB_TYPE=postgres)
DB_PATH=./backend/winner_store.db

# ─── AUTENTICACIÓN JWT ──────────────────────────────────────
# IMPORTANTE: Cambiar en producción
JWT_SECRET=dev-jwt-secret-winner-2026
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# ─── CREDENCIALES ADMIN ─────────────────────────────────────
ADMIN_USER=admin
ADMIN_PASSWORD=winner2026
# En producción: usar contraseña fuerte (>16 caracteres, números, símbolos)

ADMIN_SALT=winner_salt_2026
# Hash pre-generado (opcional, se auto-genera si no se proporciona)
# ADMIN_PASSWORD_HASH=your_hashed_password

# ─── SEGURIDAD API ──────────────────────────────────────────
API_KEY=dev-api-key
# Cambiar en producción a clave aleatoria

# ─── CORS (Control de origen) ───────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
# En producción: agregar tu dominio oficial
# Separar con comas. Dejar vacío para auto-detectar

# ─── SSL/TLS (HTTPS) ────────────────────────────────────────
# Solo ignorar para desarrollo. OBLIGATORIO en producción.
# CERT_PATH=/ruta/a/certificado.pem
# KEY_PATH=/ruta/a/clave-privada.key
HTTPS_PORT=443
HTTP_PORT=80
# Con reverse proxy (recomendado), dejar defaults

# ─── LOGGING ────────────────────────────────────────────────
LOG_LEVEL=info
# Opciones: debug | info | warn | error

# ─── LÍMITES Y TIMEOUTS ────────────────────────────────────
# Límite de tamaño de request
BODY_LIMIT=15mb

# Timeout de sesión (minutos)
SESSION_TIMEOUT=60

# ─── INTEGRACIONES FUTURAS ─────────────────────────────────
# Comentadas por ahora, descomenta cuando integres
# PAYMENT_GATEWAY=wompi|openpay|paypal
# PAYMENT_API_KEY=your_payment_api_key
# PAYMENT_WEBHOOK_SECRET=your_webhook_secret

# EMAIL_PROVIDER=sendgrid|aws-ses|mailgun
# EMAIL_FROM=noreply@winner-store.com
# EMAIL_API_KEY=your_email_api_key

# SMS_PROVIDER=twilio|aws-sns
# SMS_API_KEY=your_sms_api_key
# SMS_PHONE=+573001234567

# ─── MONITOREO ─────────────────────────────────────────────
# SENTRY_DSN=your_sentry_dsn_for_error_tracking
# ANALYTICS_ID=your_google_analytics_id
