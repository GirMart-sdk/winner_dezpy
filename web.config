<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>
    <!-- IIS Reverse Proxy a Node.js puerto 3000 -->
    <rewrite>
      <rules>
        <rule name="ReverseProxyInboundRule1" stopProcessing="true">
          <match url="(.*)" />
          <action type="Rewrite" url="http://localhost:3000/{R:1}" />
          <serverVariables>
            <set name="HTTP_X_ORIGINAL_ACCEPT_ENCODING" value="{HTTP_ACCEPT_ENCODING}" />
            <set name="HTTP_X_ORIGINAL_URL" value="/{R:1}" />
          </serverVariables>
        </rule>
      </rules>
    </rewrite>
    
    <!-- Seguridad Headers -->
    <httpProtocol>
      <customHeaders>
        <add name="X-Frame-Options" value="SAMEORIGIN" />
        <add name="X-Content-Type-Options" value="nosniff" />
        <add name="X-XSS-Protection" value="1; mode=block" />
        <add name="Referrer-Policy" value="strict-origin-when-cross-origin" />
      </customHeaders>
    </httpProtocol>

    <!-- MIME types para SQLite DB (no servir) -->
    <staticContent>
      <mimeMap fileExtension=".db" 
               mimeType="application/octet-stream" />
      <mimeMap fileExtension=".db-shm" 
               mimeType="application/octet-stream" />
      <mimeMap fileExtension=".db-wal" 
               mimeType="application/octet-stream" />
      <mimeMap fileExtension=".env" 
               mimeType="application/octet-stream" />
    </staticContent>
    
    <!-- Cache estático -->
    <staticContent>
      <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="1.00:00:00" />
    </staticContent>
  </system.webServer>
</configuration>

