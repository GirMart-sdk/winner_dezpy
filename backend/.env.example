# ═══════════════════════════════════════════════════════
# WINNER STORE — Configuración del Servidor
# ═══════════════════════════════════════════════════════

# Puerto del servidor
PORT=3000

# API Key para requests sin autenticar
API_KEY=dev-api-key

# JWT para autenticación
JWT_SECRET=dev-jwt-secret-winner-2026

# Credenciales de administrador
ADMIN_USER=admin
ADMIN_PASSWORD=winner2026
ADMIN_SALT=winner_salt_2026

# ═══════════════════════════════════════════════════════
# BASE DE DATOS — Elige una opción
# ═══════════════════════════════════════════════════════

# OPCIÓN 1: SQLite (Local, desarrollo)
DB_TYPE=sqlite
DB_PATH=./winner_store.db

# OPCIÓN 2: PostgreSQL con URL (Railway, Heroku, etc.)
# DB_TYPE=postgres
# DATABASE_URL=postgresql://user:password@host:port/database

# OPCIÓN 3: PostgreSQL con parámetros individuales
# DB_TYPE=postgres
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=winner_store
# DB_USER=postgres
# DB_PASSWORD=tu_contraseña

# ═══════════════════════════════════════════════════════
# Dominios permitidos para CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Entorno
NODE_ENV=development

# CORS - Dominios permitidos
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000

# Entorno
NODE_ENV=development
